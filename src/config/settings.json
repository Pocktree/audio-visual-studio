{
  "studioName": "AV Studio Screen Tester",
  "version": "1.0.0",
  "theme": {
    "primary": "#ffffff",
    "background": "#000000",
    "accent": "#ff0000",
    "uiOpacity": 0.9,
    "fontFamily": "'Archivo Black', 'Inter', sans-serif"
  },
  "fontSpecimens": [
    { "name": "Inter", "category": "Sans", "phrase": "THE QUICK BROWN FOX JUMPS OVER THE LAZY DOG" },
    { "name": "Playfair Display", "category": "Serif", "phrase": "Aa Bb Cc 0123456789" },
    { "name": "Space Grotesk", "category": "Display", "phrase": "ABCDEFGHIJKLMNOPQRSTUVWXYZ" },
    { "name": "Archivo Black", "category": "Display", "phrase": "0123456789 ¥$€£" },
    { "name": "IBM Plex Mono", "category": "Mono", "phrase": "function() { return true; }" },
    { "name": "Recursive", "category": "Sans", "phrase": "Aa 0O 1l Ii" },
    { "name": "Bebas Neue", "category": "Display", "phrase": "MOTION DESIGN" },
    { "name": "Syne", "category": "Display", "phrase": "CREATIVE CODING" }
  ],
  "modes": {
    "colorTest": {
      "enabled": true,
      "label": "Color Flow",
      "colors": ["#ffffff", "#000000", "#ff0000", "#00ff00", "#0000ff", "#ffff00", "#ff00ff", "#00ffff"],
      "transitionDuration": 0.5,
      "showSmpteBars": true
    },
    "gridTest": {
      "enabled": true,
      "label": "Geometry & Grids",
      "lineThickness": 1,
      "gridSizes": [20, 50, 100],
      "colors": ["#333333", "#ffffff"],
      "showCrosshair": true,
      "showCircles": true
    },
    "typoTest": {
      "enabled": true,
      "label": "Typography Stress",
      "content": "TYPE PERFORMANCE TEST 0123456789",
      "fontWeights": [100, 300, 400, 700, 900],
      "sizes": [12, 16, 24, 48, 72, 120],
      "lineHeight": 1.2,
      "letterSpacing": "-0.02em"
    },
    "noiseTest": {
      "enabled": true,
      "label": "Bit-depth & Noise",
      "grainOpacity": 0.05,
      "bitDepthSteps": 16,
      "animateNoise": true
    }
  },
  "screensaver": {
    "autoStartDelay": 30000,
    "cycleInterval": 8000,
    "randomizeOrder": true,
    "animationMode": "kinetic-typo",
    "text": "KINETIC TYPOGRAPHY Aa 0123456789",
    "transitions": {
      "type": "cross-fade",
      "ease": "easeInOutQuart"
    }
  },
  "interactive": {
    "showCursor": false,
    "enableTooltips": true,
    "sidebarPosition": "left",
    "hotkeys": {
      "toggleMenu": "m",
      "nextMode": "ArrowRight",
      "prevMode": "ArrowLeft",
      "toggleFullscreen": "f"
    }
  }
}
